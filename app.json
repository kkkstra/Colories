{
  "expo": {
    "name": "燃卡",
    "slug": "calories-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "calories",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.patrick.caloriesai"
    },
    "android": {
      "package": "com.patrick.caloriesai",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "headers": {
            "Cross-Origin-Embedder-Policy": "credentialless",
            "Cross-Origin-Opener-Policy": "same-origin"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "允许燃卡读取你选择的食物照片用于营养识别。",
          "cameraPermission": "允许燃卡使用相机拍摄食物照片。",
          "microphonePermission": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "允许燃卡使用相机拍摄食物照片。",
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": false
        }
      ],
      "expo-sqlite",
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true
        }
      ],
      [
        "expo-widgets",
        {
          "bundleIdentifier": "com.patrick.caloriesai.widgets",
          "groupIdentifier": "group.com.patrick.caloriesai",
          "widgets": [
            {
              "name": "TodayNutritionWidget",
              "displayName": "今日营养",
              "description": "查看今日热量和三大营养素进度。",
              "contentMarginsDisabled": true,
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ]
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
